name: Debug HowTheyVote

on:
  workflow_dispatch:

jobs:
  debug-howtheyvote:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pandas requests

      - name: Inspect HowTheyVote export
        run: python scripts/inspect_howtheyvote_export.py

      - name: Upload HowTheyVote schema artifact
        uses: actions/upload-artifact@v4
        with:
          name: howtheyvote-schema-debug
          path: data/debug/howtheyvote_votes_schema.json
